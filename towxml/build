const fs = require('fs-extra'),
    path = require('path'),
    os = require('os'),
    readline = require('readline'),
    config = require('./config'),
    getPathInfo = (strPath, debug) => {
        const result = {
                type: undefined,                                    // 类型 'dir'|'file'
                extension: undefined,                               // 扩展名 'undefined|空|xxx'
                name: undefined,                                    // 文件名 不包含扩展名部分
                isExist: undefined                                  // 是否存在
            };
    
        if(!strPath){
            return result;
        };
        try {
            let stat = fs.statSync(strPath);
    
            //如果路径是一个目录，则返回目录信息
            if (stat.isDirectory()) {
                result.type = 'dir';
                result.isExist = true;
    
                let backPath = path.resolve(strPath, '../'), // 跳到路径上一级目录
                    dirName = strPath.replace(backPath, ''), // 去除上级目录路径
                    re = /[/]|[\\]/g;
    
                result.name = dirName.replace(re, '');             // 去除处理路径后的/\符号
                return result;
            };
    
            if (stat.isFile()) {
                result.type = 'file';
                result.isExist = true;
            };
    
            if (stat.isSymbolicLink()){
                result.type = 'symlink';
                result.isExist = true;
            };
        } catch (error) {
            if (debug) {
                console.log(`${strPath} 文件不存在, ${error}`);
            };
        };
        result.extension = (() => {
            let extName = path.extname(strPath);
            return extName[0] === '.' ? extName.slice(1) : extName;
        })();
        result.name = path.basename(strPath, `.${result.extension}`);
        return result;
    };

class Build{
    constructor(option){
        const _ts = this;
        _ts.tplPath = path.join('decode.wxml');
        _ts.option = option;
        _ts.line = _ts.option.debug ? `\r\n` : '';

        if(option.debug){
            _ts.outDir = path.join(os.homedir(),'desktop',_ts.option.debug ? 'test' : '','towxml');
        }else{
            _ts.outDir = path.join(__dirname,'dist');
        };
        _ts.tplDir = path.join(__dirname);
    }
    
    async init(){
        const _ts = this;

        // 清空输出目录
        fs.emptyDirSync(_ts.outDir);
        const askYesNo = (question, defaultYes) => {
            return new Promise(resolve => {
                if(!process.stdin || !process.stdin.isTTY){
                    resolve(!!defaultYes);
                    return;
                }
                const rl = readline.createInterface({input:process.stdin,output:process.stdout});
                const suffix = defaultYes ? '[Y/n]' : '[y/N]';
                rl.question(`${question} ${suffix}: `, answer => {
                    rl.close();
                    const v = String(answer || '').trim().toLowerCase();
                    if(v === ''){
                        resolve(!!defaultYes);
                        return;
                    }
                    resolve(!(v === 'n' || v === 'no' || v === '0' || v === 'false'));
                });
            });
        };
        const enableHighlight = _ts.option && _ts.option.askHighlight
            ? await askYesNo('是否启用代码高亮（禁用可缩小体积）', true)
            : true;
        const removeTags = {
            'dynamic-markdown-plugins': 1,
            'dynamic-highlight-languages': 1
        };
        const stripTowxmlRemoveBlocks = str => {
            return str.replace(
                /\/\/@towxml-remove-start\s+([^\r\n]+)\r?\n([\s\S]*?)\/\/@towxml-remove-end\s+\1[^\r\n]*\r?\n?/g,
                (all, tag, body) => removeTags[String(tag).trim()] ? '' : body
            );
        };
        const updateUsingComponents = (jsonPath, fixedKeys, prefix) => {
            if(!fs.existsSync(jsonPath)){
                return;
            };
            let json;
            try {
                json = JSON.parse(fs.readFileSync(jsonPath,'utf8'));
            } catch (e) {
                return;
            };
            let original = json.usingComponents || {};
            let order = [
                ...fixedKeys,
                ...config.components.filter(item => fixedKeys.indexOf(item) === -1)
            ];
            let next = {};
            order.forEach(item => {
                if(original[item]){
                    next[item] = original[item];
                    return;
                };
                if(item === 'decode'){
                    next[item] = `${prefix}decode`;
                    return;
                };
                if(item === 'typable-text'){
                    next[item] = `${prefix}typable-text/typable-text`;
                    return;
                };
                if(item === 'batch'){
                    next[item] = `${prefix}batch/batch`;
                    return;
                };
                next[item] = `${prefix}${item}/${item}`;
            });
            json.usingComponents = next;
            fs.writeFileSync(jsonPath, JSON.stringify(json,null,2));
        };

        fs.readdirSync(_ts.tplDir).forEach(item => {
            if(item === path.basename(_ts.outDir)){
                return;
            };
            if(item === 'node_modules'){
                return;
            };
            let src = path.join(_ts.tplDir,item),
                dist = path.join(_ts.outDir,item),
                srcInfo = getPathInfo(src);

            if(srcInfo.type === 'file'){
                let allowExt = ['js','wxml','wxss','json'];
                if(allowExt.indexOf(srcInfo.extension) === -1){
                    return;
                };
                if(item === 'package.json' || item === 'package-lock.json'){
                    return;
                };
            };

            fs.copySync(src,dist,{
                filter:function(srcItem,distItem){
                    let info = getPathInfo(srcItem);
                    return info.isExist && (!info.name || info.name[0] !== '.');
                }
            });
        });

        updateUsingComponents(path.join(_ts.outDir,'towxml.json'),['decode','typable-text','batch'],'./');
        updateUsingComponents(path.join(_ts.outDir,'decode.json'),['decode','typable-text'],'./');
        updateUsingComponents(path.join(_ts.outDir,'batch','batch.json'),['decode','typable-text'],'../');

        const alwaysKeepComponentDirs = {
            'batch': 1,
            'typable-text': 1
        };
        fs.readdirSync(_ts.outDir).forEach(item => {
            const full = path.join(_ts.outDir,item);
            const info = getPathInfo(full);
            if(info.type !== 'dir'){
                return;
            };
            const componentJson = path.join(full,`${item}.json`);
            if(!fs.existsSync(componentJson)){
                return;
            };
            if(alwaysKeepComponentDirs[item] === 1){
                return;
            };
            if(config.components.indexOf(item) === -1){
                fs.removeSync(full);
            };
        });

        // highlight扩展开关处理
        let markdownIndex = path.join(_ts.outDir,'parse','markdown','index.js');
        let markdownIndexStr = fs.readFileSync(markdownIndex,'utf8');
        markdownIndexStr = stripTowxmlRemoveBlocks(markdownIndexStr);
        if(!enableHighlight){
            markdownIndexStr = markdownIndexStr.replace(
                /if\s*\(\s*config\.highlight\.length\s*&&\s*hljs\s*\)\s*\{/g,
                'if(false){'
            );
        };

        // 处理微信新版本不能动态require的问题（parse/markdown/index.js）
        const regMarkdownPluginsStr = (()=>{
            let result = ``;
            [...config.markdown,...config.components].forEach(item => {
                if(!/^audio-player|table|todogroup|img$/.test(item)){
                    result += `md.use(require('./plugins/${item}'));`
                };
            });
            return result;
        })();
        if(regMarkdownPluginsStr !== ''){
            markdownIndexStr = markdownIndexStr.replace(/\/\/@regMarkdownPlugins/g,regMarkdownPluginsStr);
        };
        fs.writeFileSync(markdownIndex,markdownIndexStr);

        const markdownPluginsDir = path.join(_ts.outDir,'parse','markdown','plugins');
        if(fs.existsSync(markdownPluginsDir)){
            const allowMarkdownPlugins = (()=>{
                let result = {};
                [...config.markdown,...config.components].forEach(item => {
                    if(!/^audio-player|table|todogroup|img$/.test(item)){
                        result[item] = 1;
                    };
                });
                return result;
            })();
            if(Object.keys(allowMarkdownPlugins).length){
                fs.readdirSync(markdownPluginsDir).forEach(file => {
                    const full = path.join(markdownPluginsDir,file);
                    const info = getPathInfo(full);
                    if(info.type !== 'file'){
                        fs.removeSync(full);
                        return;
                    };
                    const ext = path.extname(file);
                    const base = path.basename(file, ext);
                    if(ext !== '.js' || allowMarkdownPlugins[base] !== 1){
                        fs.removeSync(full);
                    };
                });
            }else{
                fs.removeSync(markdownPluginsDir);
            }
        };

        const highlightRoot = path.join(_ts.outDir,'parse','highlight');
        if(fs.existsSync(highlightRoot)){
            // 处理微信新版本不能动态require的问题（parse/highlight/index.js）
            let highlightIndex = path.join(highlightRoot,'index.js');
            if(fs.existsSync(highlightIndex)){
                let highlightIndexStr = fs.readFileSync(highlightIndex,'utf8');
                highlightIndexStr = stripTowxmlRemoveBlocks(highlightIndexStr);
                if(enableHighlight && config.highlight.length){
                    let registerLanguageStr = (()=>{
                        let result = ``;
                        config.highlight.forEach(item => {
                            result += `hljs.registerLanguage('${item}', require('./languages/${item}').default);`;
                        });
                        return result;
                    })();
                    if(registerLanguageStr){
                        highlightIndexStr = highlightIndexStr.replace(/\/\/@registerLanguage/g,registerLanguageStr);
                    };
                }
                fs.writeFileSync(highlightIndex,highlightIndexStr);
            }

            const highlightLangDir = path.join(highlightRoot,'languages');
            const highlightStyleDir = path.join(highlightRoot,'style');
            if(!enableHighlight || !config.highlight.length){
                fs.removeSync(highlightLangDir);
                fs.removeSync(highlightStyleDir);
            }else{
                // 裁剪 highlight 语言文件
                if(fs.existsSync(highlightLangDir)){
                    fs.readdirSync(highlightLangDir).forEach(file => {
                        const full = path.join(highlightLangDir,file);
                        const info = getPathInfo(full);
                        if(info.type === 'file'){
                            const ext = path.extname(file);
                            const base = path.basename(file, ext);
                            if(ext === '.js' && config.highlight.indexOf(base) === -1){
                                fs.removeSync(full);
                            };
                            if(ext !== '.js'){
                                fs.removeSync(full);
                            };
                        }else{
                            fs.removeSync(full);
                        }
                    });
                }
            }
        };

        // 如果不启用highlight组件，则注释掉对应的样式
        if(!enableHighlight || !config.highlight.length){
            let styles = (()=>{
                let files = ['dark.wxss','light.wxss'];
                files.forEach((item,index) => {
                    files[index] = path.join(_ts.outDir,'style','theme',item);
                });
                return files;
            })();

            styles.forEach(item => {
                let re = /@import .*highlight\/style\/.*;/g,
                    itemStr = fs.readFileSync(item,'utf8');

                itemStr = itemStr.replace(re,'');
                fs.writeFileSync(item,itemStr);
            });
        };

        console.log(`构建完成，请将『`,_ts.outDir,`』目录复制到小程序项目目录下${!_ts.option.debug ? '，并改名为『towxml』' : ''}`);
    }
};

(async()=>{
    await new Build({
        debug:false,
        askHighlight:true
    }).init();
})();
